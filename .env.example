# OpenAI API Key (Required)
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic API Key (Optional)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Pinecone Configuration (Required for RAG features)
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX_NAME=rag-assistant
# PINECONE_HOST= (Usually leave empty - Pinecone auto-determines the host)

# Azure Document Intelligence (Optional - for better PDF parsing)
AZURE_DOCINTEL_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
AZURE_DOCINTEL_KEY=your_azure_docintel_key_here

# Database (SQLite by default)
DATABASE_URL=sqlite:///./data/assistants.db

# Application Settings
APP_ENV=local
LOG_LEVEL=INFO
MAX_UPLOAD_SIZE_MB=50