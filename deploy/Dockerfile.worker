FROM python:3.11-slim

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    && rm -rf /var/lib/apt/lists/*

COPY pyproject.toml .
COPY src/ src/

RUN pip install --no-cache-dir -e ".[dev]"

COPY . .

ENV PYTHONPATH=/app

RUN mkdir -p /app/data

CMD ["python", "-m", "src.workflows.worker"]
